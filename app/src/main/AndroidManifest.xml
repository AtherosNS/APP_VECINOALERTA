<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.upn.app_vecinoalerta">

    <!-- ── Permisos ──────────────────────────────────────── -->

    <!-- RF-05: Botón de Pánico — marcar llamadas -->
    <uses-permission android:name="android.permission.CALL_PHONE" />

    <!-- RF-13: Captura de foto para evidencia de incidencias -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- RF-13: Galería — Android < 13 -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!-- RF-13: Galería — Android 13+ -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <!-- RF-09: Notificaciones push locales — Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- SyncManager (WorkManager) — fase 2 Firebase -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- WorkManager -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".VecinoAlertaApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.VecinoAlerta">

        <!-- ── Activities ──────────────────────────────────── -->

        <!-- Punto de entrada: Login -->
        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- RF-01: Registro de nuevos moradores -->
        <activity
            android:name=".ui.auth.RegistroActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Dashboard PROPIETARIO / RESIDENTE (Navigation Component) -->
        <activity
            android:name=".ui.main.MainDashboardActivity"
            android:exported="false" />

        <!-- Dashboard ADMINISTRADOR -->
        <activity
            android:name=".ui.admin.AdminDashboardActivity"
            android:exported="false" />

        <!-- RF-05: Pantalla de Pánico — accesible en máx 3 pasos -->
        <activity
            android:name=".ui.panico.PanicoActivity"
            android:exported="false"
            android:theme="@style/Theme.VecinoAlerta.Panico" />

        <!-- ── FileProvider para fotos de incidencias (RF-13) ── -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>