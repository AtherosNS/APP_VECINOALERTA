<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1F2C"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvReglamentoHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Reglamento Interno"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvReglamentoHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <TextView
            android:id="@+id/tvReglamento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E2E8F0"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp"
            android:fontFamily="monospace"
            android:text="Cargando reglamento..." />
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
