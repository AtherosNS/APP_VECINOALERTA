<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1F1A16"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvPasarelaTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pasarela de Pagos"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardMonto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="#2C241E"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvPasarelaTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detalle del Pago"
                android:textColor="#C4B5A8"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvMonto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total a pagar: S/ 0.00"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvMetodoTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selecciona el método de pago:"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/cardMonto"
        app:layout_constraintLeft_toLeftOf="parent" />

    <RadioGroup
        android:id="@+id/rgMetodoPago"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/tvMetodoTitle">

        <RadioButton
            android:id="@+id/rbYape"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Yape"
            android:textColor="#FFFFFF"
            android:buttonTint="#D97706"
            android:textSize="16sp"
            android:checked="true"
            android:layout_marginBottom="12dp" />

        <RadioButton
            android:id="@+id/rbPlin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Plin"
            android:textColor="#FFFFFF"
            android:buttonTint="#D97706"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <RadioButton
            android:id="@+id/rbVisa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Visa"
            android:textColor="#FFFFFF"
            android:buttonTint="#D97706"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <RadioButton
            android:id="@+id/rbMastercard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mastercard"
            android:textColor="#FFFFFF"
            android:buttonTint="#D97706"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />
    </RadioGroup>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmarPago"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Confirmar pago"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:backgroundTint="#D97706"
        app:cornerRadius="12dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
