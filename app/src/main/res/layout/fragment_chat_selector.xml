<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB"
    android:padding="24dp">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/layoutChatHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/tvChatHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mensajes"
            android:textColor="#1E293B"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02" />

        <View
            android:layout_width="60dp"
            android:layout_height="3.5dp"
            android:layout_marginTop="8dp"
            android:background="#D97706" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvChatSub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selecciona un canal de comunicación"
        android:textColor="#6B7280"
        android:textSize="14sp"
        android:layout_marginTop="2dp"
        app:layout_constraintTop_toBottomOf="@id/layoutChatHeader"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Card 1: Chat Grupal Vecinal -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardChatGrupal"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="24dp"
        app:strokeColor="#F3F4F6"
        app:strokeWidth="1.2dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvChatSub"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <!-- Ícono círculo ámbar -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="#FEF3C7"
                app:strokeWidth="0dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_chat"
                    app:tint="#D97706" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chat Vecinal"
                    android:textColor="#1F2937"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Conversa con todos los vecinos"
                    android:textColor="#6B7280"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_media_next"
                app:tint="#9CA3AF" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Card 2: Contactar Administrador (Solo para residente/propietario) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardChatAdmin"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="24dp"
        app:strokeColor="#F3F4F6"
        app:strokeWidth="1.2dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/cardChatGrupal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <!-- Ícono círculo naranja -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="#FFEDD5"
                app:strokeWidth="0dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_aprobaciones"
                    app:tint="#F97316" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Contactar Administrador"
                    android:textColor="#1F2937"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Envía un mensaje privado al administrador"
                    android:textColor="#6B7280"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_media_next"
                app:tint="#9CA3AF" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Título para la bandeja de entrada del Administrador -->
    <TextView
        android:id="@+id/tvAdminTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bandeja de Entrada (Mensajes Privados)"
        android:textColor="#1E293B"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="28dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/cardChatGrupal"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- RecyclerView para chats activos con residentes (Solo para administrador) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvActiveChats"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:visibility="gone"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/tvAdminTitle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
