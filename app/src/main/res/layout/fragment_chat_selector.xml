<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1F1A16">

    <!-- Header -->
    <TextView
        android:id="@+id/tvChatHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mensajes"
        android:textColor="#F5F5F0"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_margin="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvChatSub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selecciona un canal de comunicación"
        android:textColor="#C4B5A8"
        android:textSize="14sp"
        android:layout_marginStart="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvChatHeader"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Card: Chat Grupal Vecinal -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardChatGrupal"
        android:layout_width="0dp"
        android:layout_height="140dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="32dp"
        app:cardBackgroundColor="#2C241E"
        app:cardCornerRadius="20dp"
        app:strokeColor="#4A3C32"
        app:strokeWidth="0.5dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvChatSub"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="20dp">

            <!-- Ícono círculo ámbar -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="56dp"
                android:layout_height="56dp"
                app:cardCornerRadius="28dp"
                app:cardBackgroundColor="#3A2E1A"
                app:strokeWidth="0dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_chat"
                    app:tint="#D97706" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chat Vecinal"
                    android:textColor="#F5F5F0"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Conversa con todos los vecinos del condominio"
                    android:textColor="#C4B5A8"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_media_next"
                app:tint="#8A7A6E" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Card: Contactar Administrador -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardChatAdmin"
        android:layout_width="0dp"
        android:layout_height="140dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="#2C241E"
        app:cardCornerRadius="20dp"
        app:strokeColor="#4A3C32"
        app:strokeWidth="0.5dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/cardChatGrupal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="20dp">

            <!-- Ícono círculo naranja -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="56dp"
                android:layout_height="56dp"
                app:cardCornerRadius="28dp"
                app:cardBackgroundColor="#3A1F10"
                app:strokeWidth="0dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_aprobaciones"
                    app:tint="#F97316" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Contactar Administrador"
                    android:textColor="#F5F5F0"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Envía un mensaje directo y privado al admin"
                    android:textColor="#C4B5A8"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_media_next"
                app:tint="#8A7A6E" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
