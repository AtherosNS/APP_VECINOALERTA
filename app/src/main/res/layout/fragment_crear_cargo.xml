<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Crear Cargo Financiero"
                android:textColor="#1F2937"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <!-- Checkbox para cargo masivo -->
            <CheckBox
                android:id="@+id/cbTodosInmuebles"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Generar cargo para TODOS los inmuebles"
                android:textColor="#1F2937"
                android:buttonTint="#D97706"
                android:layout_marginBottom="20dp" />

            <!-- Seleccionar Inmueble -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selecciona el Inmueble:"
                android:textColor="#6B7280"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spinnerInmuebles"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@android:drawable/btn_dropdown"
                android:textColor="#1F2937"
                android:layout_marginBottom="20dp" />

            <!-- Seleccionar Morador -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Asignar a Morador (Opcional - Deuda Heredada si queda vacío):"
                android:textColor="#6B7280"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spinnerUsuarios"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@android:drawable/btn_dropdown"
                android:textColor="#1F2937"
                android:layout_marginBottom="20dp" />

            <!-- Concepto -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Concepto (Ej: Mantenimiento Enero)"
                android:textColorHint="#9CA3AF"
                app:boxBackgroundColor="#FFFFFF"
                app:boxCornerRadiusTopStart="24dp"
                app:boxCornerRadiusTopEnd="24dp"
                app:boxCornerRadiusBottomStart="24dp"
                app:boxCornerRadiusBottomEnd="24dp"
                app:boxStrokeWidth="1.2dp"
                app:boxStrokeColor="#F3F4F6"
                app:boxStrokeWidthFocused="1.2dp"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etConcepto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#1F2937"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Monto -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Monto (Ej: 120.00)"
                android:textColorHint="#9CA3AF"
                app:boxBackgroundColor="#FFFFFF"
                app:boxCornerRadiusTopStart="24dp"
                app:boxCornerRadiusTopEnd="24dp"
                app:boxCornerRadiusBottomStart="24dp"
                app:boxCornerRadiusBottomEnd="24dp"
                app:boxStrokeWidth="1.2dp"
                app:boxStrokeColor="#F3F4F6"
                app:boxStrokeWidthFocused="1.2dp"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etMonto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#1F2937"
                    android:inputType="numberDecimal" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Mes y Año en Horizontal -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="32dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:hint="Mes (1-12)"
                    android:textColorHint="#9CA3AF"
                    app:boxBackgroundColor="#FFFFFF"
                    app:boxCornerRadiusTopStart="24dp"
                    app:boxCornerRadiusTopEnd="24dp"
                    app:boxCornerRadiusBottomStart="24dp"
                    app:boxCornerRadiusBottomEnd="24dp"
                    app:boxStrokeWidth="1.2dp"
                    app:boxStrokeColor="#F3F4F6"
                    app:boxStrokeWidthFocused="1.2dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#1F2937"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:hint="Año"
                    android:textColorHint="#9CA3AF"
                    app:boxBackgroundColor="#FFFFFF"
                    app:boxCornerRadiusTopStart="24dp"
                    app:boxCornerRadiusTopEnd="24dp"
                    app:boxCornerRadiusBottomStart="24dp"
                    app:boxCornerRadiusBottomEnd="24dp"
                    app:boxStrokeWidth="1.2dp"
                    app:boxStrokeColor="#F3F4F6"
                    app:boxStrokeWidthFocused="1.2dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAnio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#1F2937"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCrearCargo"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Generar Cargo Financiero"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                app:backgroundTint="#D97706"
                app:cornerRadius="24dp"
                android:layout_marginBottom="40dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
