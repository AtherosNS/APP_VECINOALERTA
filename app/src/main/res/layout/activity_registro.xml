<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F9FAFB">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Bloque de color superior (Igual al Login) -->
        <View
            android:id="@+id/headerBlock"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="#D97706"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent" />

        <!-- Títulos del Registro -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/formCard">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Crear cuenta"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Únete para cuidar y proteger tu vecindario de forma organizada."
                android:textColor="#FEE2E2"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Tarjeta del Formulario Flotante -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/formCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-40dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="32dp"
            app:cardElevation="10dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/headerBlock"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Selección de Rol (Propietario / Residente) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="10dp"
                    android:text="Tipo de perfil"
                    android:textColor="#4B5563"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/rgRol"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:checkedButton="@id/rbPropietario"
                    android:layout_marginBottom="20dp"
                    android:weightSum="2">

                    <RadioButton
                        android:id="@+id/rbPropietario"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Propietario"
                        android:textColor="#374151"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:buttonTint="#D97706"
                        android:layout_marginEnd="6dp" />

                    <RadioButton
                        android:id="@+id/rbResidente"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Morador"
                        android:textColor="#374151"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:buttonTint="#D97706"
                        android:layout_marginStart="6dp" />
                </RadioGroup>

                <!-- Nombre -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="6dp"
                    android:text="Nombre"
                    android:textColor="#4B5563"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etNombre"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="César"
                    android:textColor="#1F2937"
                    android:textColorHint="#9CA3AF"
                    android:textSize="15sp"
                    android:paddingHorizontal="16dp"
                    android:inputType="textPersonName"
                    android:singleLine="true" />

                <!-- Apellido -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp"
                    android:text="Apellido"
                    android:textColor="#4B5563"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etApellido"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="Cayetano"
                    android:textColor="#1F2937"
                    android:textColorHint="#9CA3AF"
                    android:textSize="15sp"
                    android:paddingHorizontal="16dp"
                    android:inputType="textPersonName"
                    android:singleLine="true" />

                <!-- DNI -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp"
                    android:text="DNI (Documento de Identidad)"
                    android:textColor="#4B5563"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etDni"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="70228139"
                    android:textColor="#1F2937"
                    android:textColorHint="#9CA3AF"
                    android:textSize="15sp"
                    android:paddingHorizontal="16dp"
                    android:inputType="number"
                    android:maxLength="8"
                    android:singleLine="true" />

                <!-- Correo Electrónico -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp"
                    android:text="Correo electrónico"
                    android:textColor="#4B5563"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etCorreo"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="ccayetanoa1997@gmail.com"
                    android:textColor="#1F2937"
                    android:textColorHint="#9CA3AF"
                    android:textSize="15sp"
                    android:paddingHorizontal="16dp"
                    android:inputType="textEmailAddress"
                    android:singleLine="true" />

                <!-- Nombre de Usuario (Auto-generado) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp"
                    android:text="Nombre de usuario (Para chat vecinal)"
                    android:textColor="#4B5563"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etUsuario"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_input_field"
                    android:textColor="#9CA3AF"
                    android:textSize="15sp"
                    android:paddingHorizontal="16dp"
                    android:singleLine="true" />

                <!-- Bloque Dinámico: Dirección Libre (Propietario) -->
                <LinearLayout
                    android:id="@+id/layoutDireccionLibre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="6dp"
                        android:text="Dirección de tu propiedad"
                        android:textColor="#4B5563"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etDireccion"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_input_field"
                        android:hint="Mz A Lt 20"
                        android:textColor="#1F2937"
                        android:textColorHint="#9CA3AF"
                        android:textSize="15sp"
                        android:paddingHorizontal="16dp"
                        android:singleLine="true" />
                </LinearLayout>

                <!-- Bloque Dinámico: Spinner Inmueble (Residente) -->
                <LinearLayout
                    android:id="@+id/layoutSpinnerInmueble"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="6dp"
                        android:text="Selecciona tu inmueble / vivienda"
                        android:textColor="#4B5563"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinnerInmueble"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_input_field"
                        android:paddingHorizontal="8dp" />
                </LinearLayout>

                <!-- Contraseña -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp"
                    android:text="Contraseña (Min. 6 caracteres)"
                    android:textColor="#4B5563"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="••••••••"
                    android:textColor="#1F2937"
                    android:textColorHint="#9CA3AF"
                    android:textSize="15sp"
                    android:paddingHorizontal="16dp"
                    android:inputType="textPassword"
                    android:singleLine="true" />

                <!-- Confirmar Contraseña -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp"
                    android:text="Confirmar contraseña"
                    android:textColor="#4B5563"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etConfirmPassword"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="••••••••"
                    android:textColor="#1F2937"
                    android:textColorHint="#9CA3AF"
                    android:textSize="15sp"
                    android:paddingHorizontal="16dp"
                    android:inputType="textPassword"
                    android:singleLine="true" />

                <!-- Botón Registrar -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp">

                    <android.widget.Button
                        android:id="@+id/btnRegistrar"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_btn_primary"
                        android:text="Registrar"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textAllCaps="false" />

                    <ProgressBar
                        android:id="@+id/progressBar"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:visibility="gone"
                        android:indeterminateTint="#FFFFFF" />

                </FrameLayout>

                <!-- Enlace de volver al login -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="¿Ya tienes cuenta? "
                        android:textColor="#4B5563"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvVolverLogin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Inicia sesión"
                        android:textColor="#D97706"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:padding="4dp" />
                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
