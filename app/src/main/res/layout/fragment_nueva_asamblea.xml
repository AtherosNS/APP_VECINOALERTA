<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1F1A16"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvNuevaAsambleaTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Convocar Asamblea"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutTitulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Título / Tema de la Asamblea"
        android:textColorHint="#C4B5A8"
        android:layout_marginTop="24dp"
        app:boxBackgroundColor="#2C241E"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvNuevaAsambleaTitle">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etTitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:inputType="text" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutDescripcion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Detalles / Agenda de la reunión..."
        android:textColorHint="#C4B5A8"
        android:layout_marginTop="16dp"
        app:boxBackgroundColor="#2C241E"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:layout_constraintTop_toBottomOf="@id/layoutTitulo">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etDescripcion"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:textColor="#FFFFFF"
            android:gravity="top|start"
            android:inputType="textMultiLine" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnFechaHora"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Seleccionar Fecha y Hora"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:layout_marginTop="24dp"
        app:backgroundTint="#2C241E"
        app:strokeWidth="1dp"
        app:strokeColor="#D97706"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/layoutDescripcion" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConvocar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Publicar Convocatoria"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:backgroundTint="#D97706"
        app:cornerRadius="12dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
