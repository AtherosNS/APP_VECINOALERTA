<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvNuevaAsambleaTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Convocar Asamblea"
            android:textColor="#1F2937"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- Título -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutTitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Título / Tema de la Asamblea"
            android:textColorHint="#9CA3AF"
            android:layout_marginBottom="16dp"
            app:boxBackgroundColor="#FFFFFF"
            app:boxCornerRadiusTopStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxStrokeWidth="1.2dp"
            app:boxStrokeWidthFocused="1.2dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTitulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#1F2937"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Agenda / Descripción -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutDescripcion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Detalles / Agenda de la reunión..."
            android:textColorHint="#9CA3AF"
            android:layout_marginBottom="16dp"
            app:boxBackgroundColor="#FFFFFF"
            app:boxCornerRadiusTopStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxStrokeWidth="1.2dp"
            app:boxStrokeWidthFocused="1.2dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDescripcion"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:textColor="#1F2937"
                android:gravity="top|start"
                android:inputType="textMultiLine" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Lugar -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutLugar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Lugar (ej. Salón Principal, Patio, etc.)"
            android:textColorHint="#9CA3AF"
            android:layout_marginBottom="20dp"
            app:boxBackgroundColor="#FFFFFF"
            app:boxCornerRadiusTopStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxStrokeWidth="1.2dp"
            app:boxStrokeWidthFocused="1.2dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etLugar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#1F2937"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Selector de Fecha y Hora -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFechaHora"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="📅  Seleccionar Fecha y Hora"
            android:textSize="15sp"
            android:textColor="#D97706"
            app:backgroundTint="#FFFFFF"
            app:strokeWidth="1.5dp"
            app:strokeColor="#D97706"
            app:cornerRadius="16dp" />

        <!-- Confirmación de fecha seleccionada -->
        <TextView
            android:id="@+id/tvFechaSeleccionada"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#16A34A"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"
            android:visibility="gone" />

        <!-- Botón Publicar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConvocar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Publicar Convocatoria"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:backgroundTint="#D97706"
            app:cornerRadius="16dp"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>
