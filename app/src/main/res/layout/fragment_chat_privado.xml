<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB">

    <!-- Header -->
    <TextView
        android:id="@+id/tvChatPrivadoTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mensaje Privado"
        android:textColor="#1E293B"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_margin="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent" />

    <!-- RecyclerView de Mensajes -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMensajesPrivados"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/tvChatPrivadoTitle"
        app:layout_constraintBottom_toTopOf="@id/layoutInputPrivado"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent" />

    <!-- Input Bar -->
    <LinearLayout
        android:id="@+id/layoutInputPrivado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <EditText
            android:id="@+id/etMensajePrivado"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:hint="Escribe un mensaje privado..."
            android:textColorHint="#9CA3AF"
            android:textColor="#1F2937"
            android:background="@drawable/bg_input_field"
            android:paddingHorizontal="16dp"
            android:maxLines="4"
            android:textSize="15sp"
            android:inputType="textShortMessage|textAutoCorrect" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEnviarPrivado"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:text="Enviar"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textAllCaps="false"
            app:backgroundTint="#D97706"
            app:cornerRadius="24dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
