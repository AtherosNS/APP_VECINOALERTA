<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Cabecera moderna con barra de acento -->
        <LinearLayout
            android:id="@+id/layoutPerfilHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mi Perfil"
                android:textColor="#1F2937"
                android:textSize="24sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02" />

            <View
                android:layout_width="60dp"
                android:layout_height="3.5dp"
                android:layout_marginTop="8dp"
                android:background="#D97706" />
        </LinearLayout>

        <!-- Tarjeta de información del usuario -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="16dp"
            app:strokeColor="#F3F4F6"
            app:strokeWidth="1.2dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Información Personal"
                    android:textColor="#1F2937"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <!-- Fila Nombre -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nombre completo"
                    android:textColor="#6B7280"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/tvNombrePerfil"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cargando..."
                    android:textColor="#1F2937"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="12dp" />

                <!-- Fila Correo -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Correo electrónico"
                    android:textColor="#6B7280"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/tvCorreoPerfil"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cargando..."
                    android:textColor="#1F2937"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="12dp" />

                <!-- Fila Rol -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rol en el condominio"
                    android:textColor="#6B7280"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/tvRolPerfil"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cargando..."
                    android:textColor="#D97706"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Tarjeta de cambio de contraseña -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="16dp"
            app:strokeColor="#F3F4F6"
            app:strokeWidth="1.2dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cambiar Contraseña"
                    android:textColor="#1F2937"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <!-- Contraseña Actual -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutPasswordActual"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Contraseña Actual"
                    android:textColorHint="#9CA3AF"
                    android:layout_marginBottom="12dp"
                    app:passwordToggleEnabled="true"
                    app:boxBackgroundColor="#FFFFFF"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeWidth="1.2dp"
                    app:boxStrokeWidthFocused="1.2dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPasswordActual"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#1F2937"
                        android:inputType="textPassword" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Nueva Contraseña -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutPasswordNueva"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nueva Contraseña"
                    android:textColorHint="#9CA3AF"
                    android:layout_marginBottom="12dp"
                    app:passwordToggleEnabled="true"
                    app:boxBackgroundColor="#FFFFFF"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeWidth="1.2dp"
                    app:boxStrokeWidthFocused="1.2dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPasswordNueva"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#1F2937"
                        android:inputType="textPassword" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Confirmar Nueva Contraseña -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutPasswordConfirmar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Confirmar Nueva Contraseña"
                    android:textColorHint="#9CA3AF"
                    android:layout_marginBottom="20dp"
                    app:passwordToggleEnabled="true"
                    app:boxBackgroundColor="#FFFFFF"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxStrokeWidth="1.2dp"
                    app:boxStrokeWidthFocused="1.2dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPasswordConfirmar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#1F2937"
                        android:inputType="textPassword" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Botón de actualización -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnActualizarPassword"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Actualizar Contraseña"
                    android:textSize="15sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    app:backgroundTint="#D97706"
                    app:cornerRadius="12dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
