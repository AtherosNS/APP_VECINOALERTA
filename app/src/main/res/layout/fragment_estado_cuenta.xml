<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/layoutFinanzasHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent">

        <TextView
            android:id="@+id/tvFinanzasTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Estado de Cuenta"
            android:textColor="#1F2937"
            android:textSize="24sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02" />

        <View
            android:layout_width="60dp"
            android:layout_height="3.5dp"
            android:layout_marginTop="8dp"
            android:background="#D97706" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvTotalDeuda"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Total pendiente: S/ 0.00"
        android:textColor="#1F2937"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/layoutFinanzasHeader"
        app:layout_constraintLeft_toLeftOf="parent" />

    <!-- Alertas de Deudas Heredadas (Solo visible para Propietarios si aplica) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDeudasHeredadas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        app:cardCornerRadius="24dp"
        app:cardBackgroundColor="#FEF2F2"
        app:strokeColor="#EF4444"
        app:strokeWidth="1.2dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvTotalDeuda">

        <TextView
            android:id="@+id/tvAlertaDeudaHeredada"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="⚠️ Tu inmueble arrastra deudas heredadas..."
            android:textColor="#EF4444"
            android:textSize="14sp"
            android:textStyle="bold" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvSinDeudas"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¡Felicitaciones! No tienes deudas pendientes."
        android:textColor="#10B981"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCargos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/cardDeudasHeredadas"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
