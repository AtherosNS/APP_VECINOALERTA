<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1F1A16"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvFinanzasTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Estado de Cuenta"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent" />

    <TextView
        android:id="@+id/tvTotalDeuda"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Total pendiente: S/ 0.00"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvFinanzasTitle"
        app:layout_constraintLeft_toLeftOf="parent" />

    <!-- Alertas de Deudas Heredadas (Solo visible para Propietarios si aplica) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDeudasHeredadas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="#7F1D1D"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvTotalDeuda">

        <TextView
            android:id="@+id/tvAlertaDeudaHeredada"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:text="⚠️ Tu inmueble arrastra deudas heredadas..."
            android:textColor="#FCA5A5"
            android:textSize="14sp"
            android:textStyle="bold" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvSinDeudas"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¡Felicitaciones! No tienes deudas pendientes."
        android:textColor="#34D399"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCargos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/cardDeudasHeredadas"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
